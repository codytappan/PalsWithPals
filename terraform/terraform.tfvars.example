# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored so your secrets stay out of version control.

aws_region             = "us-east-1"
instance_type          = "m6i.xlarge"
data_volume_size_gb    = 20
root_volume_size_gb    = 30

# Optional: SSM parameter names used by status/health caching.
player_count_param_name = "/palworld/player_count"
data_usage_param_name   = "/palworld/data_usage_percent"

# Restrict SSH to your own IP address.
ssh_ingress_cidr       = "1.2.3.4/32"

# Optional: paste your local OpenSSH public key to enable SSH login.
# Example: cat ~/.ssh/id_ed25519.pub
ssh_public_key         = ""

# From the Discord Developer Portal (General Information tab).
discord_public_key     = "REPLACE_ME"
discord_application_id = "REPLACE_ME"

# Optional: webhook for server status notifications.
discord_webhook_url    = ""

# Game passwords.
server_password        = "REPLACE_ME"
admin_password         = "REPLACE_ME"

# Community server listing (shown in the Palworld server browser).
server_name            = "SengasPalsWithPals"
server_description     = "A friendly server for Sengas pals!"

